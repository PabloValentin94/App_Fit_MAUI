<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App_Fit_MAUI.View.Modules.ExerciseForm"
             Title="ExerciseForm">

    <ContentPage.Content>
        <Grid ColumnDefinitions="*" RowDefinitions="*,Auto" Padding="10">
            <VerticalStackLayout Grid.Column="0" Grid.Row="0">
                <Entry Text="{ Binding Id }" Keyboard="Numeric" IsVisible="Hidden" />

                <Label Text="Descrição:" />
                <Entry Text="{ Binding Description }" Keyboard="Text" Placeholder="Insira uma descrição..." />

                <Label Text="Data:" />
                <DatePicker Date="{ Binding Date }" />

                <Label Text="Peso:" />
                <Entry Text="{ Binding Weight }" Keyboard="Numeric" Placeholder="Insira o peso..." />

                <Label Text="Observações:" />
                <Entry Text="{ Binding Notes }" Keyboard="Text" Placeholder="Adicione suas observações..." />
            </VerticalStackLayout>

            <Button Grid.Column="0" Grid.Row="1" Text="Salvar" Command="{ Binding Save }" />
        </Grid>
    </ContentPage.Content>
    
</ContentPage>